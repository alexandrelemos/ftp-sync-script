# FTP connection
FTP_HOST=ftpupload.net
FTP_PORT=21
FTP_USER=YOUR_FTP_USERNAME
FTP_PASS=YOUR_FTP_PASSWORD
FTP_PATH=/htdocs

# Local workspace mapping
# If omitted, defaults to the parent folder of this script.
# Example: /Users/yourname/Documents/Frontend
WORKSPACE_DIR=

# Sync only this subfolder inside WORKSPACE_DIR
SITE_SUBDIR=al-page-gd

# Prefix used when matching .ftpignore patterns
# Keep equal to SITE_SUBDIR in most setups
WORKSPACE_PREFIX=al-page-gd

# Runtime options
PASSIVE_MODE=true
CONNECTION_TIMEOUT=10

# Optional cleanup of remote entries before upload
# Example: .github,.override,DO NOT UPLOAD FILES HERE
UNWANTED_REMOTE_ENTRIES=

# Comma-separated list for download command
DOWNLOAD_FILES=index.html,index2.html

# Optional explicit path to ignore file
# FTP_IGNORE_FILE=/absolute/path/to/.ftpignore
